# Cloudflare API credentials used by the TypeScript SDK.
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
#
# Recommended: use a scoped API token.
# Create one at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Legacy Global API Key auth (only if you cannot use an API token).
# Both must be set together.
# CLOUDFLARE_EMAIL=
# CLOUDFLARE_API_KEY=

# User Service Key auth (rarely used; specific endpoints only).
# CLOUDFLARE_API_USER_SERVICE_KEY=

# Override the default https://api.cloudflare.com/client/v4 endpoint.
# Useful for data-residency requirements (e.g. LGPD art. 33) or proxying.
# CLOUDFLARE_BASE_URL=
