# Cloudflare API credentials used by the TypeScript SDK.
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
#
# Recommended: use a scoped API token.
# Create one at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Legacy Global API Key auth (only if you cannot use an API token).
# Both must be set together.
# CLOUDFLARE_EMAIL=
# CLOUDFLARE_API_KEY=
